{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GCB NFT Credential",
  "type": "object",
  "required": ["id", "credential_type", "course_id", "wallet_address"],
  "properties": {
    "id": { "type": "string" },
    "credential_type": {
      "type": "string",
      "enum": [
        "Concordance Witness",
        "Covenant Scholar",
        "GCB Steward",
        "Ark Seal"
      ]
    },
    "course_id": { "type": "string" },
    "wallet_address": { "type": "string" },
    "issued_date": { "type": "string" },
    "metaplex_url": { "type": "string" }
  }
}